[Unit]
Description=Hosaka Field Terminal Appliance
After=network-online.target picoclaw-gateway.service
Wants=network-online.target picoclaw-gateway.service
# Kill the normal tty1 login prompt — Hosaka owns tty1
Conflicts=getty@tty1.service
After=getty@tty1.service

[Service]
Type=simple
User=operator
Group=pi
WorkingDirectory=/opt/hosaka-field-terminal
Environment=HOSAKA_STATE_PATH=/home/operator/.hosaka/state.json
Environment=PYTHONUNBUFFERED=1
Environment=HOSAKA_BOOT_MODE=console
ExecStartPre=/usr/bin/clear
ExecStart=/opt/hosaka-field-terminal/.venv/bin/python -m hosaka
Restart=always
RestartSec=2
StandardInput=tty-force
StandardOutput=tty
StandardError=tty
TTYPath=/dev/tty1

[Install]
WantedBy=multi-user.target
