#!/usr/bin/env bash
# hosaka — operator CLI for the field terminal Pi.
#
# Two main jobs:
#
#   hosaka mode build    Free up RAM/CPU on the Pi 3B so we can SSH in and
#                        run `npm run build` without the OOM killer culling
#                        the build (or worse, the SSH session).
#   hosaka mode kiosk    Restore the normal touchscreen kiosk experience.
#
# Build mode stops chromium, the openbox autostart loop, the picoclaw gateway,
# and (optionally) the webserver, and writes a marker so that on a reboot the
# Pi stays in build mode until you flip back. Kiosk mode reverses it.
#
# Convenience verbs:
#
#   hosaka status                  what's running, RAM/CPU snapshot
#   hosaka doctor [flags]          end-to-end diagnostics (runtime, tailscale, drift)
#   hosaka dev                     local repo dev: backend (:8421) + vite + electron
#   hosaka dev --web              browser-only fallback dev mode
#   hosaka dev                     if both ports are live, reuse them; if half is up, fill in the gap
#   hosaka dev -fresh             stop both backend and frontend, then relaunch cleanly
#   hosaka down                   stop both backend and frontend dev listeners
#   hosaka build [--check]         npm build (check = with tsc gate)
#   hosaka update [source|local] [--check] [--branch B]
#                                  source = git pull + deploy (default)
#                                  local  = deploy current working tree, no git pull
#   hosaka deploy [--check]        build + rsync into /opt + restart webserver
#   hosaka logs [unit]             tail journalctl for one of our units
#   hosaka reboot                  safe sync + reboot
#   hosaka mode                    show current mode + persistence
#   hosaka install picoclaw        install Picoclaw into ~/.local/bin
#   hosaka configure picoclaw      install/configure Picoclaw + import API key
#
# This script is intentionally pure bash + standard Pi tooling. It does not
# require Python, Node, or anything we install at runtime.

set -euo pipefail

# ── paths ─────────────────────────────────────────────────────────────────────

SOURCE_PATH="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE_PATH" ]]; do
  SOURCE_DIR="$(cd "$(dirname "$SOURCE_PATH")" && pwd)"
  LINK_TARGET="$(readlink "$SOURCE_PATH")"
  if [[ "$LINK_TARGET" == /* ]]; then
    SOURCE_PATH="$LINK_TARGET"
  else
    SOURCE_PATH="$SOURCE_DIR/$LINK_TARGET"
  fi
done

SCRIPT_DIR="$(cd "$(dirname "$SOURCE_PATH")" && pwd)"
if [[ -f "$SCRIPT_DIR/../frontend/package.json" && -f "$SCRIPT_DIR/../README.md" ]]; then
  DEFAULT_REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
else
  DEFAULT_REPO_ROOT="/home/operator/Hosaka"
fi

REPO_ROOT="${HOSAKA_REPO:-$DEFAULT_REPO_ROOT}"
DEPLOY_ROOT="${HOSAKA_DEPLOY:-/opt/hosaka-field-terminal}"
STATE_DIR="${HOSAKA_STATE_DIR:-/var/lib/hosaka}"
RUNTIME_MODE_FILE="$STATE_DIR/mode"
BOOT_MARKER="/boot/firmware/hosaka-build-mode"
KIOSK_AUTOSTART="${HOME:-/home/operator}/.config/openbox/autostart"

WEB_UNIT="hosaka-webserver.service"
KIOSK_UNIT="hosaka-kiosk.service"
PICO_UNIT="picoclaw-gateway.service"

# Default session key used by `hosaka chat` / `hosaka message`. Override with
# HOSAKA_AGENT_SESSION or pass `-s <name>` after the verb.
AGENT_SESSION="${HOSAKA_AGENT_SESSION:-manager}"
if [[ -z "${PICOCLAW_BIN:-}" ]]; then
  if command -v picoclaw >/dev/null 2>&1; then
    PICOCLAW_BIN="$(command -v picoclaw)"
  else
    PICOCLAW_BIN="/usr/local/bin/picoclaw"
  fi
fi
DEV_CONFLICT_RESULT="continue"

# Backend (FastAPI) for `hosaka dev`. Coupled to the frontend lifecycle —
# `hosaka dev` brings both up; `hosaka dev -fresh` restarts both; `hosaka down`
# stops both. Override with HOSAKA_BACKEND_PORT if you really need to.
BACKEND_PORT_DEFAULT="${HOSAKA_BACKEND_PORT:-8421}"
DEV_LOG_DIR_DEFAULT="${HOSAKA_DEV_LOGDIR:-$REPO_ROOT/logs/dev}"

# ── helpers ───────────────────────────────────────────────────────────────────

c_red()    { printf '\033[31m%s\033[0m' "$*"; }
c_green()  { printf '\033[32m%s\033[0m' "$*"; }
c_amber()  { printf '\033[33m%s\033[0m' "$*"; }
c_cyan()   { printf '\033[36m%s\033[0m' "$*"; }
c_dim()    { printf '\033[2m%s\033[0m' "$*"; }

note() { printf '  %s %s\n' "$(c_cyan '›')" "$*"; }
ok()   { printf '  %s %s\n' "$(c_green '✓')" "$*"; }
warn() { printf '  %s %s\n' "$(c_amber '!')" "$*"; }
die()  { printf '  %s %s\n' "$(c_red '✗')" "$*" >&2; exit 1; }

have_cmd() { command -v "$1" >/dev/null 2>&1; }

port_listener_pids() {
  local port="$1"
  if have_cmd lsof; then
    lsof -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null | awk '!seen[$0]++'
    return 0
  fi
  if have_cmd ss; then
    ss -ltnp "sport = :$port" 2>/dev/null \
      | sed -n 's/.*pid=\([0-9][0-9]*\).*/\1/p' \
      | awk '!seen[$0]++'
    return 0
  fi
  return 1
}

port_is_busy() {
  local port="$1"
  local pids
  pids="$(port_listener_pids "$port" || true)"
  [[ -n "$pids" ]]
}

open_url() {
  local url="$1"
  if have_cmd open; then
    open "$url" >/dev/null 2>&1 || true
  elif have_cmd xdg-open; then
    xdg-open "$url" >/dev/null 2>&1 || true
  fi
}

launch_dev_electron_against() {
  local port="$1"
  [[ -d "$REPO_ROOT/kiosk" ]] || die "no kiosk host at $REPO_ROOT/kiosk"
  if [[ ! -d "$REPO_ROOT/kiosk/node_modules" ]]; then
    note "kiosk deps missing — running $(c_cyan 'npm install')"
    ( cd "$REPO_ROOT/kiosk" && npm install )
  fi
  note "opening or focusing the existing hosaka electron window on $(c_cyan "http://localhost:$port")"
  ( cd "$REPO_ROOT/kiosk" \
    && HOSAKA_KIOSK_URL="http://localhost:$port" \
       HOSAKA_KIOSK_FULLSCREEN=0 \
       HOSAKA_KIOSK_DEVTOOLS="${HOSAKA_KIOSK_DEVTOOLS:-1}" \
       npx electron . )
}

kill_port_listeners() {
  local port="$1"
  local pids pid attempt
  pids="$(port_listener_pids "$port" || true)"
  [[ -n "$pids" ]] || return 0
  warn "port $port is busy — stopping listener(s): $(tr '\n' ' ' <<<"$pids" | xargs)"
  while read -r pid; do
    [[ -z "$pid" ]] && continue
    kill "$pid" 2>/dev/null || true
  done <<<"$pids"
  for attempt in 1 2 3 4 5 6; do
    if ! port_is_busy "$port"; then
      return 0
    fi
    sleep 0.5
  done
  pids="$(port_listener_pids "$port" || true)"
  [[ -z "$pids" ]] && return 0
  warn "port $port still busy — forcing listener shutdown"
  while read -r pid; do
    [[ -z "$pid" ]] && continue
    kill -9 "$pid" 2>/dev/null || true
  done <<<"$pids"
  sleep 0.5
}

kill_local_dev_electron() {
  local repo_pattern="$REPO_ROOT/kiosk"
  local pids pid
  pids="$(pgrep -f "$repo_pattern" 2>/dev/null || true)"
  [[ -n "$pids" ]] || return 0
  warn "stopping local electron/dev host process(es): $(tr '\n' ' ' <<<"$pids" | xargs)"
  while read -r pid; do
    [[ -z "$pid" ]] && continue
    kill "$pid" 2>/dev/null || true
  done <<<"$pids"
}

# ── dev backend (FastAPI) ─────────────────────────────────────────────────────

wait_for_port() {
  local port="$1"
  local timeout_ds="${2:-40}"   # tenths of seconds (default 4s)
  local i
  for (( i=0; i<timeout_ds; i++ )); do
    port_is_busy "$port" && return 0
    sleep 0.1
  done
  return 1
}

backend_pid_file() {
  echo "$DEV_LOG_DIR_DEFAULT/backend.pid"
}

backend_log_file() {
  echo "$DEV_LOG_DIR_DEFAULT/backend.log"
}

launch_dev_backend() {
  local port="$1"
  local py
  if ! py="$(_hosaka_python)"; then
    warn "no python interpreter found — backend will not start (frontend proxy will 502)"
    return 1
  fi
  mkdir -p "$DEV_LOG_DIR_DEFAULT"
  local logfile pidfile
  logfile="$(backend_log_file)"
  pidfile="$(backend_pid_file)"
  : > "$logfile"
  note "starting hosaka backend on $(c_cyan "127.0.0.1:$port") via $(c_dim "$py -m hosaka")"
  note "log → $(c_dim "$logfile")"
  (
    cd "$REPO_ROOT"
    HOSAKA_BOOT_MODE=headless \
    HOSAKA_WEB_HOST=127.0.0.1 \
    HOSAKA_WEB_PORT="$port" \
    HOSAKA_LOG_FILE="$logfile" \
    PICOCLAW_BIN="$PICOCLAW_BIN" \
    PICOCLAW_HOME="${PICOCLAW_HOME:-$HOME/.picoclaw}" \
    HOSAKA_SHELL_CWD="$REPO_ROOT" \
    nohup "$py" -m hosaka >>"$logfile" 2>&1 &
    echo $! > "$pidfile"
    disown || true
  )
  if wait_for_port "$port" 80; then
    ok "backend listening on $(c_cyan "127.0.0.1:$port")"
    return 0
  fi
  warn "backend did not bind :$port within 8s — tail $(c_dim "$logfile")"
  return 1
}

kill_dev_backend() {
  local port="${1:-$BACKEND_PORT_DEFAULT}"
  local pidfile
  pidfile="$(backend_pid_file)"
  if [[ -f "$pidfile" ]]; then
    local pid
    pid="$(cat "$pidfile" 2>/dev/null || true)"
    if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null || true
    fi
    rm -f "$pidfile"
  fi
  kill_port_listeners "$port"
}

cmd_down() {
  local port="${HOSAKA_DEV_PORT:-5173}"
  local stop_all=0

  while (( $# )); do
    case "$1" in
      --port)
        [[ $# -ge 2 ]] || die "--port needs a value"
        port="$2"
        shift 2
        ;;
      --port=*)
        port="${1#*=}"
        shift
        ;;
      --all)
        stop_all=1
        shift
        ;;
      *)
        die "unknown down arg: $1"
        ;;
    esac
  done

  if (( stop_all )); then
    local candidate
    for candidate in 5173 4173 4180 4181 4280 4281; do
      kill_port_listeners "$candidate"
    done
  else
    kill_port_listeners "$port"
  fi
  kill_local_dev_electron
  kill_dev_backend "$BACKEND_PORT_DEFAULT"
  ok "local hosaka dev processes stopped (frontend + backend)"
}

resolve_dev_port_conflict() {
  local mode="$1"
  local port="$2"
  local strategy="$3"
  local open_browser="$4"
  local url="http://localhost:$port"

  if ! port_is_busy "$port"; then
    DEV_CONFLICT_RESULT="continue"
    return 0
  fi

  case "$strategy" in
    restart)
      kill_port_listeners "$port"
      DEV_CONFLICT_RESULT="continue"
      return 0
      ;;
    reuse)
      if [[ "$mode" == "electron" ]]; then
        launch_dev_electron_against "$port"
      elif (( open_browser )); then
        note "reusing existing dev server at $(c_cyan "$url")"
        open_url "$url"
      else
        note "reusing existing dev server at $(c_cyan "$url")"
      fi
      DEV_CONFLICT_RESULT="handled"
      return 0
      ;;
    ask|"")
      ;;
    *)
      die "unknown dev conflict strategy: $strategy"
      ;;
  esac

  if [[ -t 0 && -t 1 ]]; then
    warn "port $port is already in use."
    printf '  %s %s\n' "$(c_dim '?')" "[o] open existing  [r] restart listener  [a] abort"
    while true; do
      read -r -p "  choose [o/r/a]: " choice
      case "${choice,,}" in
        o|open|reuse)
          if [[ "$mode" == "electron" ]]; then
            launch_dev_electron_against "$port"
          elif (( open_browser )); then
            note "reusing existing dev server at $(c_cyan "$url")"
            open_url "$url"
          else
            note "reusing existing dev server at $(c_cyan "$url")"
          fi
          DEV_CONFLICT_RESULT="handled"
          return 0
          ;;
        r|restart)
          kill_port_listeners "$port"
          DEV_CONFLICT_RESULT="continue"
          return 0
          ;;
        a|abort|q|quit)
          die "port $port is already in use"
          ;;
      esac
    done
  fi

  die "port $port is already in use — rerun with $(c_cyan '--reuse') to open the existing session or $(c_cyan '--restart') to stop the listener first"
}

git_repo_clean() {
  git -C "$REPO_ROOT" diff --quiet --ignore-submodules HEAD --
}

ensure_state_dir() {
  # Make sure the state dir exists AND is writable by the current user.
  # Older installs created /var/lib/hosaka root-owned, which broke `hosaka
  # mode build` for the operator. Re-chown idempotently.
  if [[ ! -d "$STATE_DIR" ]]; then
    sudo install -d -o "$(id -un)" -g "$(id -gn)" -m 0755 "$STATE_DIR"
  elif [[ ! -w "$STATE_DIR" ]]; then
    sudo chown "$(id -un)":"$(id -gn)" "$STATE_DIR"
    sudo chmod 0755 "$STATE_DIR"
  fi
}

write_runtime_mode() {
  ensure_state_dir
  if ! printf '%s\n' "$1" > "$RUNTIME_MODE_FILE" 2>/dev/null; then
    # Last-resort: write via sudo (state dir may be locked down on some hosts).
    printf '%s\n' "$1" | sudo tee "$RUNTIME_MODE_FILE" >/dev/null
    sudo chown "$(id -un)":"$(id -gn)" "$RUNTIME_MODE_FILE" 2>/dev/null || true
  fi
}

# X display used by the local tty1 session (often :0, but if another X server
# holds :0 — e.g. remote/IDE — startx may use :1, :2, …). Hardcoding :0 in
# mode_console breaks the kiosk relaunch (xsetroot/chromium → wrong DISPLAY).
kiosk_display() {
  local line disp=""
  while read -r line; do
    [[ "$line" != *vt1* ]] && continue
    # shellcheck disable=SC2001
    disp="$(sed -n 's/.*[[:space:]]\(:[0-9][0-9]*\)[[:space:]].*/\1/p' <<<"$line")"
    [[ -n "$disp" ]] && { printf '%s\n' "$disp"; return 0; }
  done < <(ps -eo args= -C Xorg 2>/dev/null)
  disp="$(ps -eo args= -C Xorg 2>/dev/null | head -1 | sed -n 's/.*[[:space:]]\(:[0-9][0-9]*\).*/\1/p')"
  [[ -n "$disp" ]] && { printf '%s\n' "$disp"; return 0; }
  printf '%s\n' ':0'
}

read_runtime_mode() {
  # Modes:
  #   console — interactive UI (chromium kiosk on the touchscreen, terminal,
  #             reading panel, etc.). The default.
  #   device  — diagnostic/SSH-friendly. Kiosk is down, picoclaw is paused,
  #             webserver stays up, screen shows the device dashboard
  #             (IP, ports, RAM, battery, disk) instead of the kiosk.
  #
  # Legacy aliases are accepted on read so we don't break older state files:
  #   "kiosk" → "console", "build" → "device".
  local raw=""
  if [[ -f "$RUNTIME_MODE_FILE" ]]; then
    raw="$(cat "$RUNTIME_MODE_FILE")"
  elif [[ -f "$BOOT_MARKER" ]]; then
    raw="device"
  else
    raw="console"
  fi
  case "$raw" in
    kiosk)        echo "console" ;;
    build)        echo "device"  ;;
    console|device) echo "$raw"  ;;
    *)            echo "console" ;;
  esac
}

ensure_frontend_deps() {
  local frontend="$REPO_ROOT/frontend"
  local npm_cmd="install"

  [[ -d "$frontend" ]] || die "no frontend at $frontend"
  have_cmd npm || die "npm not available"

  if [[ ! -d "$frontend/node_modules" ]]; then
    note "frontend deps missing — running $(c_cyan 'npm install')"
    ( cd "$frontend" && npm install )
    return 0
  fi

  # package-lock drift is the usual cause when synced frontend code adds a
  # dependency (for example `idb-keyval`) but the appliance still has an older
  # node_modules tree from before the pull.
  if [[ -f "$frontend/package-lock.json" && -f "$frontend/node_modules/.package-lock.json" ]]; then
    if [[ "$frontend/package-lock.json" -nt "$frontend/node_modules/.package-lock.json" ]]; then
      note "frontend lockfile changed — refreshing dependencies"
      ( cd "$frontend" && npm install )
      return 0
    fi
  elif [[ -f "$frontend/package-lock.json" ]]; then
    note "frontend lockfile present but install stamp missing — refreshing dependencies"
    ( cd "$frontend" && npm install )
    return 0
  fi

  if ! ( cd "$frontend" && npm ls --depth=0 idb-keyval @automerge/automerge >/dev/null 2>&1 ); then
    note "frontend dependency check failed — refreshing dependencies"
    ( cd "$frontend" && npm install )
    return 0
  fi
}

# ── mode device (was: build) ─────────────────────────────────────────────────

mode_device() {
  local persist=0
  for arg in "$@"; do
    [[ "$arg" == "--persist" ]] && persist=1
  done

  note "entering $(c_amber 'device mode') — freeing RAM/CPU for SSH workflows"

  # Kill the user-space pieces of the kiosk first. We do this WITHOUT sudo so
  # an SSH session as 'operator' can shed the kiosk. Chromium + the openbox
  # autostart relaunch loop are both owned by the operator user.
  if pgrep -u "$(id -un)" -f 'chromium.*hosaka-kiosk-profile' >/dev/null; then
    pkill -u "$(id -un)" -9 -f 'chromium.*hosaka-kiosk-profile' || true
    ok "stopped chromium kiosk"
  fi
  if pgrep -u "$(id -un)" -f '/.config/openbox/autostart' >/dev/null; then
    pkill -u "$(id -un)" -9 -f '/.config/openbox/autostart' || true
    ok "stopped openbox autostart loop"
  fi

  # Stop the heavy backend daemons. picoclaw-gateway in particular sustains
  # ~14% CPU at idle, which hurts a Pi 3B under build load.
  if systemctl is-active --quiet "$PICO_UNIT"; then
    sudo systemctl stop "$PICO_UNIT"
    ok "stopped $PICO_UNIT"
  fi
  # We KEEP hosaka-webserver running by default so you can hit the web UI from
  # another machine while the kiosk is dark. Pass `--full` to stop it too.
  if [[ " $* " == *" --full "* ]]; then
    if systemctl is-active --quiet "$WEB_UNIT"; then
      sudo systemctl stop "$WEB_UNIT"
      ok "stopped $WEB_UNIT (--full)"
    fi
  fi

  write_runtime_mode "device"
  ok "runtime mode set to $(c_amber device)"

  if (( persist )); then
    if sudo touch "$BOOT_MARKER"; then
      ok "persisted across reboot via $(c_dim "$BOOT_MARKER")"
    else
      warn "could not write $BOOT_MARKER (boot partition not writable?)"
    fi
  else
    note "this is one-shot. run with $(c_cyan '--persist') to survive reboots"
  fi

  # Make tty1 reflect the new mode RIGHT NOW. .profile is the single source
  # of truth for what runs on tty1: in device mode it execs the dashboard,
  # in console mode it execs startx. Restarting the getty re-runs autologin
  # → .profile → the right thing. Without this, switching modes leaves the
  # screen showing whatever was on it before (often: a black X session).
  refresh_tty1 "device"

  echo
  free -h | sed 's/^/    /'
}

# refresh_tty1 — make tty1 catch up to the current runtime mode without a
# reboot. Idempotent. Caller passes the target mode name purely for logging.
refresh_tty1() {
  local target="${1:-?}"
  # If a desktop X session is currently squatting tty1 (vt1), tear it down
  # first so getty can grab the vt back. Xorg runs as root so we need sudo.
  if pgrep -x Xorg >/dev/null 2>&1; then
    sudo -n pkill -9 -x Xorg 2>/dev/null || sudo pkill -9 -x Xorg 2>/dev/null || true
  fi
  if pgrep -u "$(id -un)" -x openbox >/dev/null 2>&1; then
    pkill -u "$(id -un)" -9 -x openbox 2>/dev/null || true
  fi
  if sudo -n systemctl restart getty@tty1.service 2>/dev/null \
     || sudo systemctl restart getty@tty1.service 2>/dev/null; then
    ok "tty1 refreshed for $(c_amber "$target") mode"
  else
    warn "could not restart getty@tty1.service (try: sudo systemctl restart getty@tty1)"
  fi
}

# ── mode console (was: kiosk) ────────────────────────────────────────────────

mode_console() {
  local persist=0
  for arg in "$@"; do
    [[ "$arg" == "--persist" ]] && persist=1
  done

  note "entering $(c_green 'console mode') — restoring interactive UI"

  if ! systemctl is-active --quiet "$PICO_UNIT"; then
    sudo systemctl start "$PICO_UNIT"
    ok "started $PICO_UNIT"
  fi
  if ! systemctl is-active --quiet "$WEB_UNIT"; then
    sudo systemctl start "$WEB_UNIT"
    ok "started $WEB_UNIT"
  fi

  write_runtime_mode "console"
  ok "runtime mode set to $(c_green console)"

  if (( persist )); then
    if [[ -f "$BOOT_MARKER" ]]; then
      sudo rm -f "$BOOT_MARKER" && ok "removed boot marker"
    fi
  fi

  # Console mode releases the TTY from the device dashboard service (no-op
  # if it wasn't running) and refreshes getty so .profile re-runs and starts
  # X. If openbox is already up we just re-fire the autostart in-place to
  # avoid the visible flash of restarting Xorg.
  if systemctl is-active --quiet hosaka-device-dashboard.service 2>/dev/null; then
    sudo systemctl stop hosaka-device-dashboard.service 2>/dev/null || true
  fi

  if pgrep -x Xorg >/dev/null && pgrep -u "$(id -un)" -x openbox >/dev/null; then
    # Existing X session — just (re)fire the kiosk autostart in place.
    if ! pgrep -u "$(id -un)" -f '/.config/openbox/autostart' >/dev/null; then
      kd="$(kiosk_display)"
      DISPLAY="$kd" XAUTHORITY="${HOME}/.Xauthority" \
        nohup setsid /bin/sh "$KIOSK_AUTOSTART" \
        </dev/null >/tmp/hosaka-autostart.log 2>&1 &
      disown
      ok "relaunched openbox autostart (chromium will follow)"
    else
      note "openbox autostart already running"
    fi
  else
    refresh_tty1 "console"
  fi
}

# ── status ────────────────────────────────────────────────────────────────────

cmd_status() {
  local mode
  mode="$(read_runtime_mode)"
  echo
  echo "  hosaka mode        : $(c_amber "$mode")"
  echo "  boot marker        : $([[ -f $BOOT_MARKER ]] && c_amber present || c_dim absent)"
  echo "  $WEB_UNIT  : $(systemctl is-active "$WEB_UNIT" 2>/dev/null || echo inactive)"
  echo "  $PICO_UNIT : $(systemctl is-active "$PICO_UNIT" 2>/dev/null || echo inactive)"
  if pgrep -u "$(id -un)" -f 'chromium.*hosaka-kiosk-profile' >/dev/null; then
    echo "  chromium kiosk     : $(c_green running)"
  else
    echo "  chromium kiosk     : $(c_dim stopped)"
  fi
  echo
  free -h | sed 's/^/    /'
  echo
  uptime | sed 's/^/    /'
}

# ── build / deploy ────────────────────────────────────────────────────────────

cmd_build() {
  local target="build"
  [[ "${1:-}" == "--check" ]] && target="build:check"
  [[ -d "$REPO_ROOT/frontend" ]] || die "no frontend at $REPO_ROOT/frontend"
  ensure_frontend_deps
  note "running $(c_cyan "npm run $target") in $REPO_ROOT/frontend"
  if [[ "$(read_runtime_mode)" != "device" ]]; then
    warn "not in device mode — run $(c_cyan 'hosaka mode device') first if this OOMs"
  fi
  ( cd "$REPO_ROOT/frontend" && npm run "$target" )
  ok "build done — output at $REPO_ROOT/hosaka/web/ui"
}

cmd_dev() {
  local mode="electron"
  local port="${HOSAKA_DEV_PORT:-5173}"
  local strict_port=1
  local open_browser=1
  local conflict_strategy="reuse"

  while (( $# )); do
    case "$1" in
      web|--web)
        mode="web"
        shift
        ;;
      electron|--electron)
        mode="electron"
        shift
        ;;
      --port)
        [[ $# -ge 2 ]] || die "--port needs a value"
        port="$2"
        shift 2
        ;;
      --port=*)
        port="${1#*=}"
        shift
        ;;
      --no-strict-port)
        strict_port=0
        shift
        ;;
      --reuse|--open-existing)
        conflict_strategy="reuse"
        shift
        ;;
      -)
        if [[ "${2:-}" == "fresh" ]]; then
          conflict_strategy="restart"
          shift 2
        else
          die "unknown dev arg: $1"
        fi
        ;;
      -fresh|--fresh|--restart|--restart-existing)
        conflict_strategy="restart"
        shift
        ;;
      --no-open)
        open_browser=0
        shift
        ;;
      *)
        die "unknown dev arg: $1"
        ;;
    esac
  done

  [[ -d "$REPO_ROOT/frontend" ]] || die "no frontend at $REPO_ROOT/frontend"
  ensure_frontend_deps

  # ── coupled lifecycle: backend (FastAPI :8421) + frontend (vite :$port) ──
  # The vite proxy routes /api/* and /ws/* to the backend, so a missing
  # backend means every panel sees 500/ECONNREFUSED. We keep the two glued
  # together: `hosaka dev` reuses whatever's already running, `-fresh`
  # restarts both, never a half-started pair.
  local backend_port="$BACKEND_PORT_DEFAULT"
  local fe_busy=0 be_busy=0
  port_is_busy "$port" && fe_busy=1
  port_is_busy "$backend_port" && be_busy=1

  case "$conflict_strategy" in
    restart)
      (( fe_busy )) && { note "fresh: stopping frontend on :$port"; kill_port_listeners "$port"; }
      (( be_busy )) && { note "fresh: stopping backend on :$backend_port"; kill_dev_backend "$backend_port"; }
      kill_local_dev_electron
      fe_busy=0; be_busy=0
      ;;
    reuse)
      if (( fe_busy && be_busy )); then
        note "frontend (:$port) and backend (:$backend_port) already up — reusing both"
        note "rerun with $(c_cyan 'hosaka dev -fresh') to restart the pair"
        if [[ "$mode" == "electron" ]]; then
          launch_dev_electron_against "$port"
        elif (( open_browser )); then
          note "opening $(c_cyan "http://localhost:$port")"
          open_url "http://localhost:$port"
        fi
        return 0
      fi
      if (( fe_busy != be_busy )); then
        # half-up state: warn, then bring up the missing half
        if (( fe_busy )); then
          warn "frontend on :$port is up but backend on :$backend_port is down"
        else
          warn "backend on :$backend_port is up but frontend on :$port is down"
        fi
        note "starting the missing half — use $(c_cyan 'hosaka dev -fresh') to restart both cleanly"
      fi
      ;;
  esac

  # bring up backend first so the vite proxy has something to talk to
  if (( ! be_busy )); then
    launch_dev_backend "$backend_port" || warn "continuing without backend (frontend will see 502 on /api)"
  fi

  # if frontend is already up under reuse, just attach electron/browser
  if (( fe_busy )); then
    if [[ "$mode" == "electron" ]]; then
      launch_dev_electron_against "$port"
    elif (( open_browser )); then
      note "reusing existing dev server at $(c_cyan "http://localhost:$port")"
      open_url "http://localhost:$port"
    fi
    return 0
  fi

  if [[ "$mode" == "electron" ]]; then
    [[ -d "$REPO_ROOT/kiosk" ]] || die "no kiosk host at $REPO_ROOT/kiosk"
    if [[ ! -d "$REPO_ROOT/kiosk/node_modules" ]]; then
      note "kiosk deps missing — running $(c_cyan 'npm install')"
      ( cd "$REPO_ROOT/kiosk" && npm install )
    fi
    note "launching $(c_cyan 'hosaka electron dev') on $(c_cyan "http://localhost:$port")"
    note "this is the canonical local mode — same host shape as the linux kiosk"
    note "vite + electron run together; ctrl-c tears both down"
    ( cd "$REPO_ROOT/kiosk" && VITE_PORT="$port" npm run dev )
    return 0
  fi

  note "launching $(c_cyan 'hosaka web dev') on $(c_cyan "http://localhost:$port")"
  note "browser-only fallback mode; electron remains the primary host"

  if (( open_browser )); then
    (
      sleep 2
      if have_cmd open; then
        open "http://localhost:$port" >/dev/null 2>&1 || true
      elif have_cmd xdg-open; then
        xdg-open "http://localhost:$port" >/dev/null 2>&1 || true
      fi
    ) &
  fi

  if (( strict_port )); then
    ( cd "$REPO_ROOT/frontend" && exec npm run dev -- --port "$port" --strictPort )
  else
    ( cd "$REPO_ROOT/frontend" && exec npm run dev -- --port "$port" )
  fi
}

cmd_deploy() {
  cmd_build "$@"
  if [[ -d "$DEPLOY_ROOT" ]]; then
    note "syncing python sources into $(c_cyan "$DEPLOY_ROOT/hosaka/")"
    # Rsync the entire python package so new modules (e.g. hosaka.secrets,
    # hosaka.web.voice_api) actually reach the systemd-launched webserver.
    # --delete prunes files removed in the repo so stale .pyc/.py don't keep
    # routes registered after they're deleted upstream.
    sudo rsync -a --delete \
      --exclude='__pycache__/' \
      --exclude='*.pyc' \
      "$REPO_ROOT/hosaka/" "$DEPLOY_ROOT/hosaka/"
    # Also refresh the operator-facing files most useful at runtime so a
    # stale README / scripts dir doesn't lie about what's deployed.
    if [[ -d "$REPO_ROOT/scripts" ]]; then
      sudo rsync -a --delete \
        --exclude='__pycache__/' \
        "$REPO_ROOT/scripts/" "$DEPLOY_ROOT/scripts/"
    fi
    if [[ -f "$REPO_ROOT/README.md" ]]; then
      sudo cp "$REPO_ROOT/README.md" "$DEPLOY_ROOT/README.md"
    fi
    ok "python sync done"
  else
    warn "deploy root $DEPLOY_ROOT missing — skipped rsync"
  fi
  if systemctl is-enabled --quiet "$WEB_UNIT" 2>/dev/null; then
    sudo systemctl restart "$WEB_UNIT"
    ok "restarted $WEB_UNIT"
  fi
  # The webserver serves the new hashed SPA assets, but Electron keeps the
  # already-loaded page alive until the kiosk process reloads. Restart it so
  # deploys actually reach the touchscreen without a manual reboot.
  if pgrep -u "$(id -un)" -x openbox >/dev/null 2>&1; then
    pkill -u "$(id -un)" -f "$DEPLOY_ROOT/kiosk/node_modules/.bin/electron" 2>/dev/null || true
    pkill -u "$(id -un)" -f "$DEPLOY_ROOT/kiosk/node_modules/electron/dist/electron" 2>/dev/null || true
    ok "restarted visible kiosk electron (openbox supervisor will relaunch)"
  elif systemctl is-enabled --quiet "$KIOSK_UNIT" 2>/dev/null; then
    sudo systemctl restart "$KIOSK_UNIT"
    ok "restarted $KIOSK_UNIT"
  fi
  # Voice daemon picks up new voice_api.py / tools.py / realtime_client.py
  # too. Restart it when it's enabled so the daemon side stays in sync.
  if systemctl is-enabled --quiet hosaka-voice.service 2>/dev/null; then
    sudo systemctl restart hosaka-voice.service
    ok "restarted hosaka-voice.service"
  fi
}

cmd_update() {
  # Default source = "source" (git pull + deploy). `hosaka update local`
  # builds + deploys from the working tree without touching git, so dev
  # branch experiments don't surprise the production checkout. Order is
  # flexible: `hosaka update local --check` and `hosaka update --check local`
  # both work.
  local source_mode="source"
  local target_branch=""
  local deploy_arg=""

  while (( $# )); do
    case "$1" in
      local|here|working|wt|workingtree)
        source_mode="local"
        shift
        ;;
      source|remote|origin|git|github|upstream)
        source_mode="source"
        shift
        ;;
      --check)
        deploy_arg="--check"
        shift
        ;;
      -b|--branch)
        [[ $# -ge 2 ]] || die "$1 needs a branch name"
        target_branch="$2"
        shift 2
        ;;
      --branch=*)
        target_branch="${1#*=}"
        shift
        ;;
      -h|--help|help)
        cat <<'USAGE'
hosaka update [source|local] [--check] [--branch BRANCH]

  source   (default) git fetch + checkout + ff-only pull, then build + rsync + restart
  local    skip git entirely; build the working tree as-is, then rsync + restart
  --check  run tsc gate before building
  --branch BRANCH    only meaningful with `source`; chooses which ref to ff-pull

Examples:
  hosaka update                         # pull current branch from origin, then deploy
  hosaka update source --branch dev     # ff-pull origin/dev, then deploy
  hosaka update local                   # deploy this checkout without touching git
  hosaka update local --check           # type-check then deploy this checkout
USAGE
        return 0
        ;;
      *)
        die "unknown update arg: $1 (try: hosaka update help)"
        ;;
    esac
  done

  if [[ "$source_mode" == "local" ]]; then
    note "source: $(c_cyan "local working tree") (git untouched)"
    if [[ -d "$REPO_ROOT/.git" ]] && have_cmd git && ! git_repo_clean; then
      warn "working tree has uncommitted changes — they will be deployed as-is"
    fi
    if [[ -n "$target_branch" ]]; then
      warn "--branch is ignored when source=local"
    fi
    if [[ -n "$deploy_arg" ]]; then
      cmd_deploy "$deploy_arg"
    else
      cmd_deploy
    fi
    return $?
  fi

  [[ -d "$REPO_ROOT/.git" ]] || die "no git checkout at $REPO_ROOT"
  have_cmd git || die "git not available"

  if ! git_repo_clean; then
    die "repo has local changes — commit/stash them, or use 'hosaka update local' to deploy as-is"
  fi

  if [[ -z "$target_branch" ]]; then
    target_branch="$(git -C "$REPO_ROOT" rev-parse --abbrev-ref HEAD)"
  fi

  note "source: $(c_cyan "origin/$target_branch")"
  note "fetching latest git refs in $REPO_ROOT"
  git -C "$REPO_ROOT" fetch --all --prune

  note "checking out $(c_cyan "$target_branch")"
  git -C "$REPO_ROOT" checkout "$target_branch"

  note "pulling latest changes"
  git -C "$REPO_ROOT" pull --ff-only origin "$target_branch"

  if [[ -n "$deploy_arg" ]]; then
    cmd_deploy "$deploy_arg"
  else
    cmd_deploy
  fi
}

# ── logs / reboot ─────────────────────────────────────────────────────────────

cmd_logs() {
  local unit="${1:-$WEB_UNIT}"
  case "$unit" in
    web|webserver|www) unit="$WEB_UNIT" ;;
    pico|picoclaw|gateway) unit="$PICO_UNIT" ;;
  esac
  exec journalctl -u "$unit" -f --no-pager
}

cmd_reboot() {
  note "syncing disks and rebooting in 3 s — current mode: $(c_amber "$(read_runtime_mode)")"
  sleep 3
  sync
  sudo systemctl reboot
}

# ── agent: chat / message / tui ──────────────────────────────────────────────
#
# Thin wrappers around `picoclaw agent`. The point is muscle memory:
#   hosaka chat                  → interactive REPL on the manager session
#   hosaka message <text...>     → one-shot into the manager session
#   hosaka tui                   → full Hosaka console (main_console.py)
#
# Session defaults to "manager" so planning/prioritization threads are
# persistent and distinct from ad-hoc `picoclaw agent` (cli:default) use.
# Override per-call with `-s <name>` or globally via HOSAKA_AGENT_SESSION.

_ensure_picoclaw() {
  [[ -x "$PICOCLAW_BIN" ]] || die "picoclaw not found at $PICOCLAW_BIN (set PICOCLAW_BIN=...)"
}

_hosaka_python() {
  local candidates=(
    "$REPO_ROOT/.hosakavenv/bin/python"
    "$REPO_ROOT/.venv/bin/python"
    "$(cd "$REPO_ROOT/.." && pwd)/.hosakavenv/bin/python"
    "$(cd "$REPO_ROOT/.." && pwd)/.venv/bin/python"
  )
  local candidate first=""
  # First pass: pick a venv that has uvicorn (the dev backend needs it).
  for candidate in "${candidates[@]}"; do
    if [[ -x "$candidate" ]]; then
      [[ -z "$first" ]] && first="$candidate"
      if "$candidate" -c 'import uvicorn' >/dev/null 2>&1; then
        printf '%s\n' "$candidate"
        return 0
      fi
    fi
  done
  # Fallback: first existing venv (chat/message paths don't need uvicorn).
  if [[ -n "$first" ]]; then
    printf '%s\n' "$first"
    return 0
  fi
  if command -v python >/dev/null 2>&1; then
    command -v python
    return 0
  fi
  die "no python available for hosaka commands"
}

_split_session_args() {
  # Pulls an optional leading `-s <name>` / `--session <name>` out of "$@"
  # and exports SESSION_OVERRIDE. Remaining args are left in REST[@].
  SESSION_OVERRIDE=""
  REST=()
  while (( $# )); do
    case "$1" in
      -s|--session)
        [[ $# -ge 2 ]] || die "$1 needs a session name"
        SESSION_OVERRIDE="$2"; shift 2 ;;
      -s=*|--session=*)
        SESSION_OVERRIDE="${1#*=}"; shift ;;
      --) shift; REST+=("$@"); break ;;
      *) REST+=("$1"); shift ;;
    esac
  done
}

cmd_chat() {
  _ensure_picoclaw
  _split_session_args "$@"
  local session="${SESSION_OVERRIDE:-$AGENT_SESSION}"
  note "opening chat session $(c_cyan "$session") — ctrl-d to exit"
  exec "$PICOCLAW_BIN" agent -s "$session" "${REST[@]}"
}

cmd_message() {
  _ensure_picoclaw
  _split_session_args "$@"
  local session="${SESSION_OVERRIDE:-$AGENT_SESSION}"
  if (( ${#REST[@]} == 0 )); then
    die "usage: hosaka message [-s session] <text...>  (try: hosaka chat for REPL)"
  fi
  exec "$PICOCLAW_BIN" agent -s "$session" -m "${REST[*]}"
}

cmd_tui() {
  # Full console with /chat, plant, ops, etc. Runs via the same venv the
  # webserver uses so hosaka.tui imports resolve without PYTHONPATH games.
  local py
  py="$(_hosaka_python)"
  ( cd "$REPO_ROOT" && exec "$py" -m hosaka "$@" )
}

cmd_doctor() {
  local py
  py="$(_hosaka_python)"
  ( cd "$REPO_ROOT" && exec "$py" -m hosaka.doctor "$@" )
}

cmd_diag() {
  local json=0
  local host="${HOSAKA_DIAG_HOST:-http://127.0.0.1:${BACKEND_PORT_DEFAULT}}"
  while (( $# )); do
    case "$1" in
      --json) json=1; shift ;;
      --host)
        [[ $# -ge 2 ]] || die "--host needs a URL"
        host="$2"; shift 2 ;;
      --host=*) host="${1#*=}"; shift ;;
      *) die "unknown diag arg: $1" ;;
    esac
  done
  local py
  py="$(_hosaka_python)"
  ( cd "$REPO_ROOT" && HOSAKA_DIAG_HOST="$host" HOSAKA_DIAG_JSON="$json" "$py" - <<'PY'
import json
import os
import sys
import urllib.request

host = os.environ.get("HOSAKA_DIAG_HOST", "http://127.0.0.1:8421").rstrip("/")
want_json = os.environ.get("HOSAKA_DIAG_JSON") == "1"

def fetch_snapshot():
    url = host + "/api/v1/diag/snapshot"
    try:
        with urllib.request.urlopen(url, timeout=5) as resp:
            return json.loads(resp.read().decode("utf-8")), f"api {url}"
    except Exception as exc:
        from hosaka.web.diag_api import build_snapshot
        return build_snapshot(), f"local fallback ({exc})"

def pct_bar(value, width=18):
    try:
        pct = max(0, min(100, float(value)))
    except Exception:
        pct = 0
    full = round((pct / 100) * width)
    return "█" * full + "░" * (width - full)

snap, source = fetch_snapshot()
if want_json:
    print(json.dumps(snap, indent=2, sort_keys=True))
    raise SystemExit(0)

system = snap.get("system", {})
network = snap.get("network", {})
primary = network.get("primary", {})
per = snap.get("peripherals", {})
mem = system.get("mem", {})
disk = system.get("disk_root", {})

print("\nhosaka diagnostics")
print(f"  source     : {source}")
print(f"  host       : {snap.get('hostname', 'unknown')}")
print(f"  mode       : {snap.get('mode', 'unknown')}")
print(f"  generated  : {snap.get('generated_at', '')}")
print("\nsystem")
print(f"  platform   : {system.get('platform', 'unknown')}")
print(f"  uptime     : {round(system.get('uptime_seconds', 0) / 60)} min")
print(f"  cpu temp   : {system.get('cpu_temp_c', '—')} °C")
if mem:
    total = mem.get('total_mb') or 0
    used = mem.get('used_mb') or 0
    pct = (used / total * 100) if total else 0
    print(f"  memory     : {used} / {total} MB  {pct_bar(pct)} {pct:.0f}%")
if disk:
    print(f"  disk /     : {disk.get('used_gb', '—')} / {disk.get('total_gb', '—')} GB  {pct_bar(disk.get('used_percent', 0))} {disk.get('used_percent', '—')}%")
print("\nnetwork")
print(f"  ip         : {primary.get('ip') or primary.get('tailscale_ip') or '—'}")
print(f"  iface      : {primary.get('iface') or '—'}")
print(f"  ssid       : {primary.get('ssid') or '—'}")
print(f"  ports      : {', '.join(map(str, network.get('listening_ports', []))) or '—'}")
print("\nperipherals")
for name in ("audio", "video", "usb", "bluetooth", "battery"):
    item = per.get(name, {}) or {}
    state = "detected" if item.get("available") else "not detected"
    print(f"  {name:<10} : {state}")
print("\nservices")
for svc in system.get("services", []):
    dot = "●" if svc.get("active") else "○"
    print(f"  {dot} {svc.get('name')} — {svc.get('sub')}")
PY
  )
}

cmd_install() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    die "usage: hosaka install picoclaw [--onboard]"
  fi
  shift || true
  case "$target" in
    picoclaw|pico)
      ( cd "$REPO_ROOT" && exec bash scripts/install-picoclaw.sh "$@" )
      ;;
    openclaw)
      warn "OpenClaw is not wired to a canonical Hosaka adapter yet."
      warn "Use Picoclaw for the stable local agent path today."
      warn "Set HOSAKA_AGENT_BACKEND=openclaw later once an OpenClaw CLI/adapter is selected."
      ;;
    *)
      die "unknown install target: $target (try: picoclaw)"
      ;;
  esac
}

cmd_configure() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    die "usage: hosaka configure picoclaw [--onboard|--no-onboard]"
  fi
  shift || true
  case "$target" in
    picoclaw|pico)
      ( cd "$REPO_ROOT" && exec bash scripts/configure-picoclaw.sh "$@" )
      ;;
    openclaw)
      warn "OpenClaw is the planned heavier desktop-agent backend."
      warn "No canonical OpenClaw adapter is wired in this checkout yet."
      warn "Use: hosaka configure picoclaw"
      ;;
    *)
      die "unknown configure target: $target (try: picoclaw)"
      ;;
  esac
}

# ── secrets ──────────────────────────────────────────────────────────────────

# Pick the python that has hosaka importable. Prefer the deployed venv (used
# by systemd), then the repo venv, then the bare interpreter.
secrets_python() {
  local candidates=(
    "$DEPLOY_ROOT/.venv/bin/python"
    "$REPO_ROOT/.venv/bin/python"
    "$REPO_ROOT/.hosakavenv/bin/python"
  )
  local p
  for p in "${candidates[@]}"; do
    if [[ -x "$p" ]]; then
      printf '%s\n' "$p"
      return 0
    fi
  done
  if have_cmd python; then
    command -v python
    return 0
  fi
  command -v python3
}

# Where the repo's hosaka package actually lives, so the chosen python can
# import it even when running from /opt/hosaka-field-terminal.
secrets_pythonpath() {
  if [[ -d "$REPO_ROOT/hosaka" ]]; then
    printf '%s\n' "$REPO_ROOT"
  elif [[ -d "$DEPLOY_ROOT/hosaka" ]]; then
    printf '%s\n' "$DEPLOY_ROOT"
  fi
}

run_secrets_module() {
  local py
  py="$(secrets_python)" || die "no python interpreter found"
  local extra_path
  extra_path="$(secrets_pythonpath)"
  if [[ -n "$extra_path" ]]; then
    PYTHONPATH="$extra_path${PYTHONPATH:+:$PYTHONPATH}" "$py" -m hosaka.secrets "$@"
  else
    "$py" -m hosaka.secrets "$@"
  fi
}

run_secrets_module_root() {
  # Re-invoke ourselves under sudo so writes to /etc/hosaka/env succeed and
  # hidden-prompt UX (getpass) still flows through the user's tty.
  local py
  py="$(secrets_python)" || die "no python interpreter found"
  local extra_path
  extra_path="$(secrets_pythonpath)"
  if (( EUID == 0 )); then
    if [[ -n "$extra_path" ]]; then
      PYTHONPATH="$extra_path${PYTHONPATH:+:$PYTHONPATH}" "$py" -m hosaka.secrets "$@"
    else
      "$py" -m hosaka.secrets "$@"
    fi
    return $?
  fi
  if ! have_cmd sudo; then
    warn "sudo not available; running unprivileged. /etc/hosaka/env mirror may fail."
    if [[ -n "$extra_path" ]]; then
      PYTHONPATH="$extra_path${PYTHONPATH:+:$PYTHONPATH}" "$py" -m hosaka.secrets "$@"
    else
      "$py" -m hosaka.secrets "$@"
    fi
    return $?
  fi
  if [[ -n "$extra_path" ]]; then
    sudo -E env "PYTHONPATH=$extra_path${PYTHONPATH:+:$PYTHONPATH}" \
      "HOSAKA_SECRETS_PATH=${HOSAKA_SECRETS_PATH:-$HOME/.hosaka/secrets.json}" \
      "$py" -m hosaka.secrets "$@"
  else
    sudo -E env \
      "HOSAKA_SECRETS_PATH=${HOSAKA_SECRETS_PATH:-$HOME/.hosaka/secrets.json}" \
      "$py" -m hosaka.secrets "$@"
  fi
}

cmd_secrets() {
  local verb="${1:-list}"
  shift || true
  case "$verb" in
    list|ls)
      run_secrets_module list "$@"
      ;;
    get)
      run_secrets_module get "$@"
      ;;
    check|doctor)
      run_secrets_module check "$@"
      ;;
    path)
      run_secrets_module path "$@"
      ;;
    set)
      run_secrets_module_root set "$@"
      ;;
    unset|rm|remove)
      run_secrets_module_root unset "$@"
      ;;
    mirror)
      run_secrets_module_root mirror "$@"
      ;;
    import-picoclaw|import|adopt)
      run_secrets_module_root import-picoclaw "$@"
      ;;
    edit)
      run_secrets_module edit "$@"
      ;;
    -h|--help|help|"")
      cat <<'USAGE'
hosaka secrets — manage Hosaka's environment secrets

  hosaka secrets list                   show every known key (redacted)
  hosaka secrets check [--no-probe]     presence + format + live OpenAI probe
  hosaka secrets get NAME [--reveal]    print one secret (redacted by default)
  hosaka secrets set NAME [VALUE]       store a secret (prompts hidden if VALUE omitted; sudo)
  hosaka secrets unset NAME             remove a secret (sudo)
  hosaka secrets mirror                 rewrite /etc/hosaka/env from the JSON store (sudo)
  hosaka secrets import-picoclaw        copy OPENAI_API_KEY from ~/.picoclaw/.security.yml (sudo)
  hosaka secrets edit                   open /etc/hosaka/env in $EDITOR via sudoedit
  hosaka secrets path                   print the JSON + env file paths

Storage:
  ~/.hosaka/secrets.json  source of truth (chmod 600)
  /etc/hosaka/env         mirror used by systemd EnvironmentFile (chmod 640)
USAGE
      ;;
    *)
      die "unknown secrets verb: $verb (try: list|check|get|set|unset|mirror|import-picoclaw|edit|path)"
      ;;
  esac
}

# ── dispatch ──────────────────────────────────────────────────────────────────

usage() {
  cat <<USAGE
hosaka — operator CLI for the Hosaka Field Terminal Pi

  hosaka mode                       show current mode (console|device)
  hosaka mode console [--persist]   interactive UI on the touchscreen
                                    --persist  remove boot marker
  hosaka mode device  [--persist] [--full]
                                    diagnostic + ssh-friendly. Stops kiosk,
                                    pauses picoclaw, shows device dashboard
                                    (IPs/ports/RAM/battery) on tty1.
                                    --persist  survive reboots
                                    --full     also stop hosaka-webserver

  Aliases (legacy): \`hosaka mode kiosk\` → console, \`hosaka mode build\` → device

  hosaka status                     what's running + memory snapshot
  hosaka down [--port N] [--all]    stop local dev listeners/windows for this checkout
  hosaka dashboard                  print the device dashboard once and exit
  hosaka diag [--json] [--host URL] shared device/network/peripheral snapshot
  hosaka doctor [--json] [--strict] [--profile PROFILE] [--host URL]
                                    run structured diagnostics; future MCP-friendly
  hosaka dev [--port N] [--no-open] [-fresh]
                                    local frontend dev without docker.
                                    default = vite + electron; reuses existing session if port is busy
                                    use -fresh to restart the listener first; use --web for browser-only fallback
  hosaka build [--check]            npm run build (--check runs tsc gate first)
  hosaka update [source|local] [--check] [--branch BRANCH]
                                    source (default) git pull + build + rsync + restart
                                    local  deploy current working tree without touching git
                                    `hosaka update help` for more
  hosaka deploy [--check]           build + rsync into $DEPLOY_ROOT + restart web
  hosaka logs [unit]                follow journalctl for web/pico/<custom>
  hosaka reboot                     sync + reboot
  hosaka install picoclaw [--onboard]
                                    install Picoclaw into ~/.local/bin and bootstrap Hosaka runtime
  hosaka configure picoclaw [--onboard|--no-onboard]
                                    install/check Picoclaw and import OPENAI_API_KEY if available
  hosaka secrets <verb>             manage env secrets (list|check|set|unset|mirror|import-picoclaw|edit)

  hosaka chat [-s session]          open interactive agent REPL
                                    (default session: \$HOSAKA_AGENT_SESSION = $AGENT_SESSION)
  hosaka message [-s session] TEXT  one-shot message into agent session
  hosaka tui                        launch full Hosaka console (python -m hosaka)

Typical SSH-then-deploy flow:
  hosaka mode device                 # frees RAM
  cd ~/Hosaka && hosaka update
  hosaka mode console                # touchscreen back

Typical local dev flow:
  hosaka dev                         # backend (:8421) + vite + electron, all together
  hosaka dev                         # if both ports are live, reuse them; otherwise fill in what's missing
  hosaka dev -fresh                  # stop backend + frontend, then relaunch the pair cleanly
  hosaka down                        # stop the local dev session cleanly
  hosaka dev --web                   # browser-only fallback on localhost:5173
USAGE
}

main() {
  local cmd="${1:-status}"
  shift || true
  case "$cmd" in
    mode)
      local sub="${1:-show}"
      shift || true
      case "$sub" in
        device|build) mode_device "$@" ;;
        console|kiosk) mode_console "$@" ;;
        show|status|"") echo "  current mode: $(c_amber "$(read_runtime_mode)")" ;;
        *) die "unknown mode: $sub (try console|device|show)" ;;
      esac
      ;;
    status)    cmd_status "$@" ;;
    down)      cmd_down "$@" ;;
    dashboard) exec /usr/local/bin/hosaka-device-dashboard --once ;;
    diag)      cmd_diag "$@" ;;
    doctor)    cmd_doctor "$@" ;;
    dev)       cmd_dev "$@" ;;
    build)     cmd_build "$@" ;;
    update)    cmd_update "$@" ;;
    deploy)    cmd_deploy "$@" ;;
    install)   cmd_install "$@" ;;
    configure) cmd_configure "$@" ;;
    secrets)   cmd_secrets "$@" ;;
    logs)      cmd_logs "$@" ;;
    reboot)    cmd_reboot "$@" ;;
    chat|agent|repl) cmd_chat "$@" ;;
    message|msg|say) cmd_message "$@" ;;
    tui|console-ui)  cmd_tui "$@" ;;
    -h|--help|help) usage ;;
    *) usage; die "unknown command: $cmd" ;;
  esac
}

main "$@"
