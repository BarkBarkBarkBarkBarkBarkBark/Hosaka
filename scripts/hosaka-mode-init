#!/bin/sh
# hosaka-mode-init — invoked once at boot by hosaka-mode.service.
#
# Reads the boot-time marker file and mirrors it into the runtime state file.
# Two modes:
#   console — interactive UI (touchscreen kiosk + picoclaw + webserver)
#   device  — diagnostic + ssh-friendly (kiosk paused, picoclaw stopped,
#             webserver up, dashboard on tty1)
#
# Legacy: the marker file is named hosaka-build-mode for backward compat
# with installations that wrote it under the old "build mode" name.

set -eu

BOOT_MARK="/boot/firmware/hosaka-build-mode"
STATE_DIR="/var/lib/hosaka"
MODE_FILE="$STATE_DIR/mode"

mkdir -p "$STATE_DIR"
# Make the state dir operator-writable so `hosaka mode` doesn't need sudo
# for the runtime mode file write. The service file ID 1000 here matches
# the appliance install's first user; on other hosts the chown is a no-op.
chown 1000:1000 "$STATE_DIR" 2>/dev/null || true

if [ -f "$BOOT_MARK" ]; then
    echo "device" > "$MODE_FILE"
    echo "[hosaka-mode-init] boot marker present — entering DEVICE mode"
    systemctl stop picoclaw-gateway.service 2>/dev/null || true
else
    echo "console" > "$MODE_FILE"
    echo "[hosaka-mode-init] no boot marker — entering CONSOLE mode"
fi

chmod 0644 "$MODE_FILE"
chown 1000:1000 "$MODE_FILE" 2>/dev/null || true
exit 0
