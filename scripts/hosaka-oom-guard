#!/usr/bin/env python3
"""hosaka-oom-guard — pre-emptive memory pressure watchdog.

Background:
  The Pi 3B has 1 GiB RAM and SD-card swap. Once swap starts thrashing the
  SD-card subsystem can deadlock (kworker mmc_rescan blocked > 120 s) and
  take the whole box down. The kernel OOM killer never gets a chance to fire
  cleanly — by then we're already locked.

Strategy:
  Sample /proc/meminfo every POLL_SECS. If we cross either of two thresholds
  in a row (MemAvailable < AVAIL_MB_WARN or SwapUsed > SWAP_MB_WARN), take
  graduated action and capture a snapshot:

    LEVEL 1 (warn)   – log + drop disk caches (pagecache only, free).
    LEVEL 2 (action) – kill chromium kiosk + openbox autostart loop.
                       Switch runtime mode to "device" so they don't respawn.
    LEVEL 3 (panic)  – stop picoclaw-gateway via sudo (whitelisted).

Snapshots go to /var/log/hosaka/oom-guard.log (handled by logrotate, see
/etc/logrotate.d/hosaka — we just append, the rotator caps disk usage).

This script intentionally has no third-party deps and a tiny RSS itself
(~12 MB resident). It is the LAST thing we want to be heavy.
"""
from __future__ import annotations

import os
import signal
import subprocess
import sys
import time
from datetime import datetime, timezone
from pathlib import Path

# ── tunables (override via env) ───────────────────────────────────────────────

POLL_SECS         = int(os.getenv("HOSAKA_GUARD_POLL_SECS", "10"))
AVAIL_MB_WARN     = int(os.getenv("HOSAKA_GUARD_AVAIL_MB_WARN", "150"))
AVAIL_MB_ACTION   = int(os.getenv("HOSAKA_GUARD_AVAIL_MB_ACTION", "100"))
SWAP_MB_WARN      = int(os.getenv("HOSAKA_GUARD_SWAP_MB_WARN", "300"))
SWAP_MB_ACTION    = int(os.getenv("HOSAKA_GUARD_SWAP_MB_ACTION", "500"))
LOAD_PANIC        = float(os.getenv("HOSAKA_GUARD_LOAD_PANIC", "10.0"))
COOLDOWN_SECS     = int(os.getenv("HOSAKA_GUARD_COOLDOWN_SECS", "120"))

LOG_DIR           = Path(os.getenv("HOSAKA_GUARD_LOG_DIR", "/var/log/hosaka"))
LOG_FILE          = LOG_DIR / "oom-guard.log"
SNAPSHOT_FILE     = LOG_DIR / "oom-snapshot.log"
RUNTIME_MODE_FILE = Path("/var/lib/hosaka/mode")
KIOSK_USER        = os.getenv("HOSAKA_KIOSK_USER", "operator")
PICO_UNIT         = "picoclaw-gateway.service"
WEB_UNIT          = "hosaka-webserver.service"

_LAST_ACTION_AT   = 0.0  # epoch; LEVEL-2/3 cooldown


# ── meminfo parsing ───────────────────────────────────────────────────────────

def _meminfo() -> dict[str, int]:
    """Returns MemTotal/MemAvailable/SwapTotal/SwapFree in MiB."""
    out: dict[str, int] = {}
    try:
        for line in Path("/proc/meminfo").read_text().splitlines():
            k, _, rest = line.partition(":")
            try:
                out[k] = int(rest.strip().split()[0]) // 1024  # KiB → MiB
            except (ValueError, IndexError):
                continue
    except OSError:
        pass
    return out


def _loadavg() -> float:
    try:
        return float(Path("/proc/loadavg").read_text().split()[0])
    except (OSError, ValueError, IndexError):
        return 0.0


# ── logging ───────────────────────────────────────────────────────────────────

def _ts() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def log(level: str, msg: str) -> None:
    line = f"{_ts()} [{level}] {msg}\n"
    sys.stdout.write(line)
    sys.stdout.flush()
    try:
        LOG_DIR.mkdir(parents=True, exist_ok=True)
        with LOG_FILE.open("a", encoding="utf-8") as f:
            f.write(line)
    except OSError:
        pass


def snapshot(reason: str, mem: dict[str, int]) -> None:
    """Capture top-15 RSS + free + load + journal tail for diagnosis."""
    try:
        LOG_DIR.mkdir(parents=True, exist_ok=True)
        with SNAPSHOT_FILE.open("a", encoding="utf-8") as f:
            f.write(f"\n──── {_ts()} — {reason} ────\n")
            for cmd in (
                ["free", "-h"],
                ["uptime"],
                ["bash", "-c", "ps -eo pid,user,rss,pcpu,comm --sort=-rss | head -16"],
                ["bash", "-c", "cat /proc/pressure/memory 2>/dev/null || true"],
            ):
                f.write(f"$ {' '.join(cmd)}\n")
                try:
                    f.write(subprocess.run(cmd, capture_output=True, text=True, timeout=4).stdout)
                except Exception as e:  # noqa: BLE001
                    f.write(f"  (failed: {e})\n")
                f.write("\n")
            f.write(f"meminfo: {mem}\n")
    except OSError:
        pass


# ── action helpers ────────────────────────────────────────────────────────────

def _run(cmd: list[str], timeout: int = 5) -> tuple[int, str]:
    try:
        p = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout, check=False)
        return p.returncode, (p.stdout + p.stderr).strip()
    except FileNotFoundError:
        return 127, f"not found: {cmd[0]}"
    except subprocess.TimeoutExpired:
        return 124, "timeout"


def drop_caches() -> None:
    """LEVEL 1 — release pagecache. Cheap, no side-effects."""
    try:
        Path("/proc/sys/vm/drop_caches").write_text("1\n")
        log("WARN", "dropped pagecache")
    except OSError as e:
        log("WARN", f"could not drop_caches: {e}")


def kill_kiosk() -> int:
    """LEVEL 2 — terminate chromium kiosk + openbox autostart loop."""
    killed = 0
    for pattern in ("chromium.*hosaka-kiosk-profile", "/.config/openbox/autostart"):
        rc, _ = _run(["pkill", "-u", KIOSK_USER, "-9", "-f", pattern])
        if rc == 0:
            killed += 1
            log("ACTION", f"pkill -9 -f '{pattern}'")
    return killed


def force_device_mode() -> None:
    """LEVEL 2 — flip runtime mode marker so kiosk won't respawn."""
    try:
        RUNTIME_MODE_FILE.parent.mkdir(parents=True, exist_ok=True)
        RUNTIME_MODE_FILE.write_text("device\n")
        log("ACTION", f"runtime mode → device ({RUNTIME_MODE_FILE})")
    except OSError as e:
        log("WARN", f"could not write {RUNTIME_MODE_FILE}: {e}")


def stop_picoclaw() -> None:
    """LEVEL 3 — try to stop the picoclaw gateway. Needs sudoers entry."""
    rc, out = _run(["sudo", "-n", "systemctl", "stop", PICO_UNIT], timeout=10)
    if rc == 0:
        log("ACTION", f"stopped {PICO_UNIT}")
    else:
        log("WARN", f"could not stop {PICO_UNIT}: {out[:200]}")


# ── decision loop ─────────────────────────────────────────────────────────────

def step() -> None:
    global _LAST_ACTION_AT
    mem = _meminfo()
    avail = mem.get("MemAvailable", 9999)
    swap_total = mem.get("SwapTotal", 0)
    swap_free = mem.get("SwapFree", 0)
    swap_used = max(swap_total - swap_free, 0)
    load = _loadavg()

    is_action = (avail <= AVAIL_MB_ACTION) or (swap_used >= SWAP_MB_ACTION) or (load >= LOAD_PANIC)
    is_warn   = (avail <= AVAIL_MB_WARN)   or (swap_used >= SWAP_MB_WARN)

    cooldown_active = (time.time() - _LAST_ACTION_AT) < COOLDOWN_SECS

    if is_action and not cooldown_active:
        log("ACTION", f"avail={avail}MB swap={swap_used}MB load={load:.2f} → engaging")
        snapshot(f"action avail={avail}MB swap={swap_used}MB load={load:.2f}", mem)
        drop_caches()
        kill_kiosk()
        force_device_mode()
        if (avail <= AVAIL_MB_ACTION // 2) or (swap_used >= SWAP_MB_ACTION + 200):
            stop_picoclaw()
        _LAST_ACTION_AT = time.time()
    elif is_warn:
        log("WARN", f"avail={avail}MB swap={swap_used}MB load={load:.2f}")
        if not cooldown_active:
            drop_caches()


def main() -> int:
    LOG_DIR.mkdir(parents=True, exist_ok=True)
    log("INFO", (
        f"hosaka-oom-guard up. poll={POLL_SECS}s "
        f"warn(avail<{AVAIL_MB_WARN}MB|swap>{SWAP_MB_WARN}MB) "
        f"action(avail<{AVAIL_MB_ACTION}MB|swap>{SWAP_MB_ACTION}MB|load>{LOAD_PANIC})"
    ))
    stop = False
    def _stop(_sig, _fr):  # noqa: ANN001
        nonlocal stop
        stop = True
    signal.signal(signal.SIGTERM, _stop)
    signal.signal(signal.SIGINT, _stop)
    while not stop:
        try:
            step()
        except Exception as e:  # noqa: BLE001
            log("ERROR", f"step failed: {e}")
        # interruptible sleep so SIGTERM is responsive
        for _ in range(POLL_SECS * 2):
            if stop:
                break
            time.sleep(0.5)
    log("INFO", "hosaka-oom-guard stopping")
    return 0


if __name__ == "__main__":
    sys.exit(main())
