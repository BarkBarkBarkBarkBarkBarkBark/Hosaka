{
  "openapi": "3.1.0",
  "info": {
    "title": "Hosaka Appliance",
    "description": "API for the Hosaka Field Terminal Pi. The `/api/v1/*` surface is the public, versioned contract that hosakactl (Mac/Linux client) and the kiosk SPA both consume. See the published reference at https://<your-gh-user>.github.io/Hosaka/ for static docs.",
