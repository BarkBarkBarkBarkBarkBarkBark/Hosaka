            "type": "string",
            "title": "Name"
          },
          "active": {
            "type": "boolean",
            "title": "Active"
          },
          "sub": {
            "type": "string",
            "title": "Sub"
          },
          "enabled": {
            "type": "boolean",
            "title": "Enabled"
