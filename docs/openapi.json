        },
        "type": "object",
        "required": [
          "name",
          "active",
          "sub",
          "enabled"
        ],
        "title": "ServiceInfo"
      },
      "SystemInfoOut": {
        "properties": {
          "mode": {
            "type": "string",
            "enum": [
              "console",
              "device"
            ],
            "title": "Mode"
          },
          "boot_marker": {
            "type": "boolean",
            "title": "Boot Marker"
          },
          "hostname": {
            "type": "string",
            "title": "Hostname"
          },
          "uptime_seconds": {
            "type": "integer",
