              "console",
              "device"
            ],
            "title": "Mode"
          },
          "hostname": {
            "type": "string",
            "title": "Hostname"
          },
          "uptime_seconds": {
            "type": "integer",
            "title": "Uptime Seconds"
          },
          "timestamp": {
            "type": "integer",
            "title": "Timestamp"
